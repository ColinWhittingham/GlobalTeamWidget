<Window
    x:Class="GlobalTeamWidget.UI.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Edit Location"
    Width="500" Height="680"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Background="#F3F3F3">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      GlassFrameThickness="0,0,0,0"
                      ResizeBorderThickness="0"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
                <ResourceDictionary Source="ButtonStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Thin title bar with custom close button -->
        <Grid Grid.Row="0" Background="#F3F3F3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="WindowTitleText" Grid.Column="0"
                       Text="Edit Location" VerticalAlignment="Center"
                       Margin="16,0" FontSize="13" Foreground="#1A1A1A" />
            <Button Grid.Column="1" Content="✕"
                    Style="{StaticResource CloseBtn}"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    Click="OnCloseWindow" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,0,24,24">
            <StackPanel>

                <TextBlock Text="Location" FontSize="16" FontWeight="SemiBold"
                           FontFamily="Segoe UI Variable Display" Margin="0,0,0,12" />

                <ui:Card Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Search city" FontSize="13" Foreground="#555" Margin="0,0,0,6" />
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox x:Name="CitySearchBox" Grid.Column="0"
                                        PlaceholderText="e.g. Tokyo" Margin="0,0,8,0" />
                            <Button x:Name="SearchButton" Grid.Column="1"
                                    Style="{StaticResource SecondaryBtn}"
                                    Content="Search" Click="OnSearchCity" />
                        </Grid>
                        <TextBlock x:Name="GeocodingStatus" Foreground="#C42B1C"
                                   Visibility="Collapsed" TextWrapping="Wrap" FontSize="12" />

                        <Separator Margin="0,10" />

                        <TextBlock Text="Display name" FontSize="13" Foreground="#555" Margin="0,0,0,6" />
                        <ui:TextBox x:Name="DisplayNameBox" PlaceholderText="e.g. Tokyo HQ"
                                    MaxLength="30" Margin="0,0,0,12" />

                        <TextBlock Text="Timezone (IANA)" FontSize="13" Foreground="#555" Margin="0,0,0,6" />
                        <ui:TextBox x:Name="TimezoneBox" PlaceholderText="e.g. Asia/Tokyo"
                                    Margin="0,0,0,12" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Currency (ISO 4217)" FontSize="13" Foreground="#555" Margin="0,0,0,6" />
                                <ui:TextBox x:Name="CurrencyBox" PlaceholderText="e.g. JPY" MaxLength="3" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Country (ISO 3166-1)" FontSize="13" Foreground="#555" Margin="0,0,0,6" />
                                <ui:TextBox x:Name="CountryBox" PlaceholderText="e.g. JP" MaxLength="2" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <TextBlock Text="Working Hours" FontSize="16" FontWeight="SemiBold"
                           FontFamily="Segoe UI Variable Display" Margin="0,4,0,12" />

                <ui:Card Margin="0,0,0,12">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Start (HH:mm)" FontSize="13" Foreground="#555" Margin="0,0,0,6" />
                                <ui:TextBox x:Name="WorkStartBox" Text="09:00" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="End (HH:mm)" FontSize="13" Foreground="#555" Margin="0,0,0,6" />
                                <ui:TextBox x:Name="WorkEndBox" Text="17:00" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Working days" FontSize="13" Foreground="#555" Margin="0,0,0,10" />
                        <WrapPanel>
                            <CheckBox x:Name="DayMon" Content="Mon" Margin="0,0,14,6" />
                            <CheckBox x:Name="DayTue" Content="Tue" Margin="0,0,14,6" />
                            <CheckBox x:Name="DayWed" Content="Wed" Margin="0,0,14,6" />
                            <CheckBox x:Name="DayThu" Content="Thu" Margin="0,0,14,6" />
                            <CheckBox x:Name="DayFri" Content="Fri" Margin="0,0,14,6" />
                            <CheckBox x:Name="DaySat" Content="Sat" Margin="0,0,14,6" />
                            <CheckBox x:Name="DaySun" Content="Sun" />
                        </WrapPanel>
                    </StackPanel>
                </ui:Card>

                <TextBlock Text="Global Settings" FontSize="16" FontWeight="SemiBold"
                           FontFamily="Segoe UI Variable Display" Margin="0,4,0,12" />

                <ui:Card Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Base currency (ISO 4217)" FontSize="13" Foreground="#555" Margin="0,0,0,6" />
                        <ui:TextBox x:Name="BaseCurrencyBox" PlaceholderText="e.g. GBP" MaxLength="3" />
                    </StackPanel>
                </ui:Card>

                <TextBlock x:Name="ValidationMessage" Foreground="#C42B1C"
                           Visibility="Collapsed" TextWrapping="Wrap" FontSize="12" Margin="0,0,0,12" />

                <StackPanel Orientation="Horizontal">
                    <Button Content="Save" Style="{StaticResource PrimaryBtn}" Click="OnSave"
                            MinWidth="90" Margin="0,0,8,0" />
                    <Button Content="Cancel" Style="{StaticResource SecondaryBtn}" Click="OnCancel"
                            MinWidth="90" Margin="0,0,8,0" />
                    <Button x:Name="RemoveButton" Content="Remove location"
                            Style="{StaticResource DangerBtn}" Click="OnRemove"
                            Visibility="Collapsed" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
