<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Shared rounded button control template -->
    <ControlTemplate x:Key="RoundedBtnTemplate" TargetType="Button">
        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                CornerRadius="5" Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Opacity" Value="0.88" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Opacity" Value="0.75" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- Base -->
    <Style x:Key="GtwBtn" TargetType="Button">
        <Setter Property="Template"   Value="{StaticResource RoundedBtnTemplate}" />
        <Setter Property="Padding"    Value="16,8" />
        <Setter Property="FontSize"   Value="13" />
        <Setter Property="Cursor"     Value="Hand" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- Primary — Windows 11 accent blue -->
    <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource GtwBtn}">
        <Setter Property="Background" Value="#0067C0" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- Secondary — neutral grey, dark text -->
    <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource GtwBtn}">
        <Setter Property="Background" Value="#E1E1E1" />
        <Setter Property="Foreground" Value="#1A1A1A" />
    </Style>

    <!-- Danger — red -->
    <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource GtwBtn}">
        <Setter Property="Background" Value="#C42B1C" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- Close (✕) caption button — transparent, goes red on hover like Windows 11 -->
    <Style x:Key="CloseBtn" TargetType="Button">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width"     Value="46" />
        <Setter Property="Height"    Value="40" />
        <Setter Property="FontSize"  Value="12" />
        <Setter Property="Cursor"    Value="Arrow" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#1A1A1A" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#C42B1C" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#A82518" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
