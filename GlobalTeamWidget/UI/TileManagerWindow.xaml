<Window
    x:Class="GlobalTeamWidget.UI.TileManagerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Global Team Widget"
    Width="560" Height="520"
    WindowStartupLocation="CenterScreen"
    Background="#F3F3F3">

    <WindowChrome.WindowChrome>
        <!-- Removes grey chrome bar; Windows 11 auto-adds rounded corners -->
        <WindowChrome CaptionHeight="40"
                      GlassFrameThickness="0,0,0,0"
                      ResizeBorderThickness="4"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
                <ResourceDictionary Source="ButtonStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />   <!-- Custom title bar -->
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Thin title bar with custom close button -->
        <Grid Grid.Row="0" Background="#F3F3F3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Global Team Widget"
                       VerticalAlignment="Center" Margin="16,0"
                       FontSize="13" Foreground="#1A1A1A" />
            <Button Grid.Column="1" Content="✕"
                    Style="{StaticResource CloseBtn}"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    Click="OnCloseWindow" />
        </Grid>

        <Grid Grid.Row="1" Margin="24,0,24,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="Locations" FontSize="20" FontWeight="SemiBold"
                           FontFamily="Segoe UI Variable Display" Margin="0,0,0,4" />
                <TextBlock Text="Add and manage your team locations (up to 8)."
                           Foreground="#666" FontSize="13" />
            </StackPanel>

            <ListView x:Name="TileList" Grid.Row="1"
                      SelectionMode="Single" BorderThickness="0" Background="Transparent">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Margin="0,3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock Text="{Binding SubTitle}"
                                               Foreground="#666" FontSize="12" Margin="0,2,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1" Content="Edit" Margin="8,0,0,0"
                                        Style="{StaticResource SecondaryBtn}"
                                        Tag="{Binding TileId}" Click="OnEditTile" />
                                <Button Grid.Column="2" Content="Remove" Margin="6,0,0,0"
                                        Style="{StaticResource DangerBtn}"
                                        Tag="{Binding TileId}" Click="OnRemoveTile" />
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <Grid Grid.Row="2" Margin="24,12,24,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button x:Name="AddButton" Grid.Column="0"
                    Style="{StaticResource PrimaryBtn}"
                    Content="＋  Add location" Click="OnAddTile" />
            <TextBlock x:Name="SlotCount" Grid.Column="1" VerticalAlignment="Center"
                       Margin="16,0,0,0" Foreground="#666" FontSize="12" />
        </Grid>
    </Grid>
</Window>
