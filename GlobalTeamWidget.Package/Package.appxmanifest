<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:mp="http://schemas.microsoft.com/appx/2014/phone/manifest"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
  xmlns:com="http://schemas.microsoft.com/appx/manifest/com/windows10"
  xmlns:com2="http://schemas.microsoft.com/appx/manifest/com/windows10/2"
  IgnorableNamespaces="mp uap uap3 com com2">

  <Identity
    Name="GlobalTeamWidget"
    Publisher="CN=GlobalTeamWidget"
    Version="1.0.0.0" />

  <mp:PhoneIdentity PhoneProductId="gtw-001" PhonePublisherId="00000000-0000-0000-0000-000000000000"/>

  <Properties>
    <DisplayName>Global Team Widget</DisplayName>
    <PublisherDisplayName>Global Team Widget</PublisherDisplayName>
    <Logo>Assets\StoreLogo.scale-100.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Universal" MinVersion="10.0.22000.0" MaxVersionTested="10.0.26100.0" />
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.22000.0" MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-US"/>
  </Resources>

  <Applications>
    <Application Id="App"
      Executable="GlobalTeamWidget.exe"
      EntryPoint="$targetentrypoint$">
      <uap:VisualElements
        DisplayName="Global Team Widget"
        Description="Monitor your distributed team locations at a glance"
        BackgroundColor="transparent"
        Square150x150Logo="Assets\WidgetIcon.scale-100.png"
        Square44x44Logo="Assets\WidgetIcon.scale-100.png">
        <uap:DefaultTile Wide310x150Logo="Assets\WidgetIcon.scale-100.png" />
      </uap:VisualElements>
      <Extensions>
        <!-- Widget provider registration -->
        <uap3:Extension Category="windows.appExtension">
          <uap3:AppExtension
            Name="com.microsoft.windows.widgets"
            DisplayName="Global Team Widget"
            Description="Monitor up to 8 global team locations"
            Id="GlobalTeamWidget"
            PublicFolder="Public">
            <uap3:Properties>
              <WidgetProvider>
                <ProviderIcons>
                  <Icon Path="Assets\WidgetIcon.scale-100.png" />
                </ProviderIcons>
                <Activation>
                  <CreateInstance ClassId="A1B2C3D4-E5F6-7890-ABCD-EF1234567890" />
                </Activation>
                <Definitions>
                  <Definition
                    Id="GlobalTeamWidget_Main"
                    DisplayName="Global Team Widget"
                    Description="Monitor your distributed team locations at a glance"
                    AllowMultiple="false">
                    <Capabilities>
                      <Capability Type="configuration" />
                    </Capabilities>
                    <Sizes>
                      <Size Name="large" />
                    </Sizes>
                  </Definition>
                </Definitions>
              </WidgetProvider>
            </uap3:Properties>
          </uap3:AppExtension>
        </uap3:Extension>
        <!-- COM server registration for widget provider -->
        <com:Extension Category="windows.comServer">
          <com:ComServer>
            <com2:ExeServer Executable="GlobalTeamWidget.exe" DisplayName="Global Team Widget Provider">
              <com:Class Id="A1B2C3D4-E5F6-7890-ABCD-EF1234567890" DisplayName="GlobalTeamWidgetProvider" />
            </com2:ExeServer>
          </com:ComServer>
        </com:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <Capability Name="internetClient" />
  </Capabilities>

</Package>
